{
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devPath": "http://localhost:1420",
    "distDir": "../dist"
  },
  "package": {
    "productName": "Research Pilot",
    "version": "1.0.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": { "all": false, "open": true, "sidecar": true, "execute": true },
      "dialog": { "all": true, "open": true, "save": true },
      "fs": {
        "all": true,
        "scope": ["$DOCUMENT/*", "$DOWNLOAD/*", "$DESKTOP/*", "$HOME/*"]
      },
      "path": { "all": true }
    },
    "bundle": {
      "active": true,
      "targets": "all",
      "identifier": "com.researchpilot.app",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ],
      "externalBin": ["binaries/worker"]
    },
    "security": { "csp": null },
    "windows": [{
      "title": "Research Pilot",
      "width": 1200,
      "height": 780,
      "minWidth": 900,
      "minHeight": 600,
      "resizable": true,
      "fullscreen": false
    }]
  }
}
